{
  "name": "magic-brush-runtime",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:all": "bun run test && bun run test:api && bun run test:frontend",
    "test:api": "bun run --cwd apps/api test",
    "test:frontend": "bun run --cwd apps/frontend test",
    "dev:api": "bun run --cwd apps/api dev",
    "dev:frontend": "bun run --cwd apps/frontend dev",
    "turn": "bun src/cli/run-turn.ts",
    "turn:repl": "bun src/cli/run-turn-repl.ts"
  },
  "devDependencies": {
    "@esbuild/darwin-arm64": "^0.21.5",
    "@types/node": "^25.3.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8",
    "zod": "^3.24.1"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "openai": "^6.25.0",
    "zod-to-json-schema": "^3.25.1"
  }
}
